# ---------------------------------------------------------------------------
# Finboard environment configuration
# ---------------------------------------------------------------------------
# Local dev is ZERO-CONFIG: leave DATABASE_URL unset (or set a path) and
# Finboard uses an embedded PGlite Postgres file at ./.finboard-data.
# `npm run dev` creates the schema and seeds a demo account automatically.
#
# For production, point DATABASE_URL at a real Postgres (e.g. Neon). When it
# starts with postgresql:// (or postgres://) Finboard uses a standard Prisma
# client against that server instead of the local PGlite file.

# --- Local PGlite (default, zero-config) ---
# Option A: leave DATABASE_URL blank to use ./.finboard-data
# Option B: set a path (must NOT contain "://") for a custom PGlite directory
# DATABASE_URL="./.finboard-data"

# --- Production Postgres / Neon (uncomment and fill in) ---
# DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/finboard?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3100"

# Optional Google OAuth (leave blank to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Stock market data (Investments feature) ---
# Leave blank to use the built-in SIMULATED market feed (no API key, works
# out of the box). Provide a Finnhub key to switch to live real-time quotes
# automatically — the app selects the provider from this variable alone.
# STOCK_API_KEY="your-finnhub-key"
