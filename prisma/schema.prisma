// Prisma schema for Finboard — mirrors 04-db-schema.md
// Provider is postgresql (Neon). Run `npm run db:push` to create tables.

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  avatarUrl     String?
  currency      String    @default("INR")
  createdAt     DateTime  @default(now())

  accounts      Account[]
  transactions  Transaction[]
  categories    Category[]
  budgets       Budget[]
  goals         Goal[]
  recurring     RecurringTxn[]
  holdings      Holding[]
  trades        Trade[]
}

model Account {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        String // cash | bank | card | wallet
  balance     Decimal  @default(0)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())

  transactions Transaction[]

  @@index([userId])
}

model Category {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  key       String // food | transport | shopping | bills | fun | health | savings
  icon      String?
  color     String?
  isDefault Boolean @default(false)

  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  type        String // income | expense
  amount      Decimal
  note        String?
  tags        String[]
  receiptUrl  String?
  date        DateTime
  createdAt   DateTime @default(now())

  @@index([userId, date])
}

model Budget {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  limit       Decimal
  period      String   @default("monthly") // monthly | weekly
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  targetAmount  Decimal
  currentAmount Decimal    @default(0)
  deadline      DateTime?
  accountId    String?
  createdAt     DateTime   @default(now())

  @@index([userId])
}

model RecurringTxn {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  amount      Decimal
  categoryId  String?
  frequency   String // weekly | monthly | yearly
  nextDueDate DateTime
  active      Boolean   @default(true)

  @@index([userId])
}

model Holding {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  name      String
  shares    Decimal  @default(0)
  avgCost   Decimal  @default(0)
  createdAt DateTime @default(now())

  trades    Trade[]

  @@index([userId])
  @@index([userId, symbol])
}

model Trade {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdingId String?
  holding   Holding? @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  symbol    String
  type      String   // buy | sell
  shares    Decimal
  price     Decimal
  note      String?
  date      DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([holdingId])
}
